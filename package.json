    "@types/node-cron": "^3.0.11",
    "@supabase/supabase-js": "^2.105.4",
    "argon2": "^0.44.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1",
    "framer-motion": "^11.11.1",
    "gsap": "^3.15.0",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.453.0",
    "node-cron": "^4.2.1",
