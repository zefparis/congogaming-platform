# ---- Frontend (Vite) ----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
# WhatsApp support phone number (digits only, with or without leading +).
VITE_SUPPORT_PHONE=243997174834
# Public play URL used for agent QR codes and referral links.
VITE_PLAY_URL=https://www.congogaming.com

# ---- Backend (Fastify) ----
PORT=3001
# Use 127.0.0.1 locally — only set 0.0.0.0 in production/Railway
HOST=127.0.0.1
ALLOWED_ORIGINS=https://congogaming.com,https://www.congogaming.com,https://congogaming-platform-staging.vercel.app,http://localhost:5173

# !! REQUIRED !! JWT signing secret (min 64 chars). Server will not start without it.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=changeme_generate_a_real_secret_min_64_chars

# Auth lockout: max failed PIN attempts before temporary lockout.
AUTH_MAX_FAILURES=5
# Auth lockout duration in minutes.
AUTH_LOCKOUT_MINUTES=15
# Access token TTL in seconds (default 900 = 15 min).
ACCESS_TOKEN_TTL_SECONDS=900

UNIPESA_PUBLIC_ID=
UNIPESA_MERCHANT_ID=
UNIPESA_SECRET_KEY=
UNIPESA_CALLBACK_URL=https://your-api-domain.com/api/callback
# Fixie static-IP proxy (Render add-on). Leave empty to bypass proxy.
FIXIE_URL=http://fixie:USER@ventoux.usefixie.com:80

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=

# Admin dashboard (/admin route). Use a cryptographically random secret (min 32 chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LOTO_ADMIN_SECRET=
# Flash (Loto Express) admin secret for manual draw triggers.
FLASH_ADMIN_SECRET=
# Loto & Flash jackpot seed amounts in CDF.
LOTO_JACKPOT_CDF=500000
FLASH_JACKPOT_CDF=500000
# Minimum tickets required before a draw can be triggered.
LOTO_MIN_TICKETS=0
FLASH_MIN_TICKETS=0

# ---- PlayGuard KYC (server-side only — never expose to the frontend) ----
# Real PlayGuard API key. The Congo Gaming backend forwards selfies through
# the PlayGuard Vercel Edge proxy (PG_PROXY_URL) using this key.
PG_API_KEY=
# Override only if running a non-default deploy of PlayGuard.
PG_PROXY_URL=https://playguard.vercel.app/api/proxy

# ---- UniPay CGLT gaming integration (server-to-server) ----
# UniPay API base URL for CGLT gaming deposits/withdrawals.
UNIPAY_API_URL=
# Shared API key for UniPay CGLT gaming integration.
GAMING_API_KEY=

# ---- Feature flags ----
# Enable/disable Congo Loto game.
CONGO_LOTO_ENABLED=true
# Enable/disable Okapi Color game.
OKAPI_COLOR_ENABLED=true
# Enable/disable referral program.
REFERRAL_PROGRAM_ENABLED=true

# ---- Okapi Color configuration ----
# Admin secret for Okapi Color draw/purge endpoints.
OKAPI_COLOR_ADMIN_SECRET=
# Jackpot seed amount in CDF.
OKAPI_COLOR_JACKPOT_CDF=500000
# Contribution per ticket to the jackpot (CDF).
OKAPI_COLOR_CONTRIBUTION_CDF=100
# Draw interval in seconds.
OKAPI_COLOR_DRAW_INTERVAL_SECONDS=300
# Close ticket sales N seconds before draw.
OKAPI_COLOR_CLOSE_BEFORE_SECONDS=60
# How long results are displayed after draw (seconds).
OKAPI_COLOR_RESULT_DISPLAY_SECONDS=30
# Drawing window duration (seconds).
OKAPI_COLOR_DRAWING_WINDOW_SECONDS=10
