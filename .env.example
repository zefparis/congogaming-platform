# ---- Frontend (Vite) ----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
VITE_GAME_IFRAME_URL=https://adipredictstreet.com

# ---- Backend (Fastify) ----
PORT=3001
# Use 127.0.0.1 locally — only set 0.0.0.0 in production/Railway
HOST=127.0.0.1
ALLOWED_ORIGINS=https://congogaming.com,https://www.congogaming.com,https://congogaming-platform-staging.vercel.app,http://localhost:5173

UNIPESA_PUBLIC_ID=
UNIPESA_MERCHANT_ID=
UNIPESA_SECRET_KEY=
UNIPESA_CALLBACK_URL=https://your-api-domain.com/api/callback
# Fixie static-IP proxy (Render add-on). Leave empty to bypass proxy.
FIXIE_URL=http://fixie:USER@ventoux.usefixie.com:80

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=

# Admin dashboard (/admin route). Use a cryptographically random secret (min 32 chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LOTO_ADMIN_SECRET=

# ---- PlayGuard KYC (server-side only — never expose to the frontend) ----
# Real PlayGuard API key. The Congo Gaming backend forwards selfies through
# the PlayGuard Vercel Edge proxy (PG_PROXY_URL) using this key.
PG_API_KEY=
# Override only if running a non-default deploy of PlayGuard.
PG_PROXY_URL=https://playguard.vercel.app/api/proxy

# ---- PredictStreet sports-betting widget ----
# Bearer token for server-to-server limits API (GET /api/predictstreet/users/:id/limits)
PREDICTSTREET_BEARER_TOKEN=
# HMAC-SHA256 secret for inbound webhook (POST /api/predictstreet/limits/webhook)
PREDICTSTREET_WEBHOOK_SECRET=
# RSA private key (PEM) for JWT minting — ephemeral if unset
PREDICTSTREET_RSA_PRIVATE_KEY=
# Partner ID provided by PredictStreet at onboarding
PREDICTSTREET_PARTNER_ID=
